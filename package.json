{
  "name": "resiliencekit",
  "version": "0.1.0",
  "description": "Composable resilience patterns: retry (with exponential backoff/jitter), circuit breaker, timeout, fallback. Inspired by Polly (.NET) and Tenacity (Python). Zero dependencies, TypeScript.",
  "keywords": [
    "retry",
    "circuit-breaker",
    "timeout",
    "resilience",
    "polly",
    "tenacity",
    "backoff",
    "exponential-backoff",
    "fallback",
    "fault-tolerance",
    "zero-dependency",
    "typescript"
  ],
  "author": "trananhtung",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trananhtung/resiliencekit.git"
  },
  "homepage": "https://github.com/trananhtung/resiliencekit#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
